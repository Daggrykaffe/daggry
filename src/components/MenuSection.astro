---
interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="menu-section opacity-0 translate-y-5 animate-slide-up">
	<header class="mb-8 max-sm:mb-6">
		<h2 class="font-serif text-[2.2rem] font-bold tracking-[-0.01em] m-0 leading-[1.2] max-sm:text-[1.8rem]">{title}</h2>
		{subtitle && <p class="font-sans text-[0.9rem] text-text-light mt-1">{subtitle}</p>}
	</header>
	
	<div class="flex flex-col gap-6">
		<slot />
	</div>
</section>

<style>
	.menu-section:nth-child(1) { animation-delay: 0.1s; }
	.menu-section:nth-child(2) { animation-delay: 0.2s; }
	.menu-section:nth-child(3) { animation-delay: 0.3s; }
	.menu-section:nth-child(4) { animation-delay: 0.4s; }
	.menu-section:nth-child(5) { animation-delay: 0.5s; }
</style>
