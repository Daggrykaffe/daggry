---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg 
	class={className} 
	viewBox="0 0 200 120" 
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
>
	<!-- Text path for curved text -->
	<defs>
		<path id="text-curve" d="M 40 45 Q 100 20 160 45" fill="transparent" />
	</defs>

	<!-- Curved text -->
	<text font-family="var(--font-typewriter)" font-size="28" fill="currentColor" letter-spacing="0.1em">
		<textPath href="#text-curve" startOffset="50%" text-anchor="middle">
			daggry
		</textPath>
	</text>

	<!-- Sun -->
	<path d="M 50 80 A 50 50 0 0 1 150 80" fill="currentColor" />
	
	<!-- Horizon line -->
	<line x1="10" y1="80" x2="190" y2="80" stroke="currentColor" stroke-width="2.5" />
	
	<!-- Reflection lines -->
	<line x1="40" y1="88" x2="160" y2="88" stroke="currentColor" stroke-width="2.5" />
	<line x1="60" y1="96" x2="140" y2="96" stroke="currentColor" stroke-width="2.5" />
	<line x1="85" y1="104" x2="115" y2="104" stroke="currentColor" stroke-width="2.5" />
</svg>

<style>
	svg {
		display: block;
		color: var(--color-text);
	}
</style>
